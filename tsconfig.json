{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": [
    "app",
    ".nuxt"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".nuxt",
    "legacy-archive"
  ]
}
